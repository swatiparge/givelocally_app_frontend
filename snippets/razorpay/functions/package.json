{
  "name": "givelocally-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for GiveLocally - Razorpay Promise Fee Integration",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions,pubsub,firestore",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "dotenv": "^16.6.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.0.5",
    "razorpay": "^2.8.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
