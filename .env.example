# Firebase Environment Configuration
# Copy this file to .env and fill in your production values

# Firebase Configuration
FIREBASE_API_KEY=your_production_api_key
FIREBASE_AUTH_DOMAIN=givelocally-prod.firebaseapp.com
FIREBASE_PROJECT_ID=givelocally-prod
FIREBASE_STORAGE_BUCKET=givelocally-prod.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef
FIREBASE_IOS_BUNDLE_ID=com.givelocally.app

# Functions Region
FUNCTIONS_REGION=asia-south1

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Environment Mode
FLUTTER_APP_FLAVOR=production
